# WorkPulse — developer / build configuration
#
# Copy this file to .env and fill in the values.
# This file is only needed when running from source or building the DMG.
# Colleagues installing the DMG don't need this — OAuth is bundled in the app.

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL:    http://localhost:3333
#   Callback URL:    http://localhost:3333/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Slack App ---
# Create at: https://api.slack.com/apps → Create New App → From scratch
#   Add redirect URL: http://localhost:3333/auth/slack/callback
#   User Token Scopes: search:read, users:read, channels:read, im:read, mpim:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Google (Calendar + Gmail) ---
# Create at: https://console.cloud.google.com/apis/credentials
#   Type: Web application
#   Redirect URI: http://localhost:3333/auth/google/callback
#   Enable: Google Calendar API, Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Server ---
PORT=3333
# Set to 0 to disable auto-opening the browser on npm start
OPEN_BROWSER=1
