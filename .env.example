# --- GitHub ---
# Personal access token with `repo` and `read:user` scopes
GITHUB_TOKEN=ghp_xxx
GITHUB_USERNAME=davidkocnar

# --- Slack ---
# User token (xoxp-...) with search:read scope. Bot tokens (xoxb-) cannot use search.messages.
SLACK_TOKEN=xoxp-xxx

# --- Jira / Tempo ---
JIRA_BASE_URL=https://thefuntasty.atlassian.net
JIRA_EMAIL=david.kocnar@futured.app
JIRA_API_TOKEN=xxx

# Tempo Cloud API token (Settings -> Apps -> Tempo -> API Integration)
TEMPO_TOKEN=xxx

# --- Server ---
PORT=3333
# Set to 0 to disable auto-opening the browser
OPEN_BROWSER=1
