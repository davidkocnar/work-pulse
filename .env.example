# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Homepage URL: http://localhost:3333
#   Callback URL: http://localhost:3333/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Slack App ---
# Create at: https://api.slack.com/apps → Create New App → From scratch
#   Add redirect URL: http://localhost:3333/auth/slack/callback
#   User Token Scopes: search:read, users:read, channels:read, im:read, mpim:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Jira / Tempo ---
# Jira API token: https://id.atlassian.com/manage-profile/security/api-tokens
# Tempo token: Tempo → Settings → API Integration → New Token
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

TEMPO_TOKEN=

# --- Google (Calendar + Gmail) ---
# OAuth 2.0 Web client from https://console.cloud.google.com/apis/credentials
# Redirect URI to add: http://localhost:3333/auth/google/callback
# Required APIs: Google Calendar API, Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Server ---
PORT=3333
# Set to 0 to disable auto-opening the browser
OPEN_BROWSER=1
